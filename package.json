{
  "name": "react-zero-skeleton",
  "version": "2.0.0",
  "description": "The component IS the skeleton. Auto-measured at runtime, always in sync, zero maintenance. React & React Native.",
  "keywords": [
    "skeleton",
    "skeleton-loader",
    "loader",
    "react-native",
    "react",
    "placeholder",
    "content-placeholder",
    "shimmer",
    "loading",
    "animation",
    "shatter",
    "zero-config",
    "bone",
    "expo",
    "nextjs",
    "typescript",
    "adaptive",
    "network-aware",
    "auto-skeleton"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/J-Ben/skelter"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "react-native": "dist/native/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./dist/native/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./devtools": {
      "react-native": "./dist/devtools/native/index.js",
      "import": "./dist/devtools/index.mjs",
      "require": "./dist/devtools/index.js",
      "types": "./dist/devtools/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.70.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.73.0",
    "jest": "^29.0.0",
    "react-native-svg": "^15.15.5",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "pnpm": {
    "overrides": {
      "human-id": "4.1.3"
    }
  }
}
