{
  "name": "react-zero-skeleton",
  "version": "0.3.2",
  "description": "Stop writing skeleton loaders. Auto-generated from your component layout.",
  "keywords": [
    "skeleton",
    "loader",
    "react-native",
    "react",
    "placeholder",
    "shimmer",
    "loading",
    "animation",
    "shatter",
    "zero-config"
  ],
  "license": "MIT",
  "author": "",
  "repository": {
    "type": "git",
    "url": "https://github.com/J-Ben/skelter"
  },
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "react-native": "dist/native/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "react-native": "./dist/native/index.js",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "jest --passWithNoTests",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "prepublishOnly": "npm run build",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "peerDependencies": {
    "react": ">=17.0.0",
    "react-native": ">=0.70.0"
  },
  "peerDependenciesMeta": {
    "react-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.0",
    "@testing-library/react": "^14.0.0",
    "@testing-library/react-native": "^12.0.0",
    "@types/jest": "^29.0.0",
    "@types/node": "^25.6.0",
    "@types/react": "^18.0.0",
    "@types/react-native": "^0.73.0",
    "jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
